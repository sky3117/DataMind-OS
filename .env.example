# ============================================
# DataMind OS – Environment Configuration
# ============================================
# Copy this file to .env and fill in values:
#   cp .env.example .env

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# --- Database ---
DATABASE_URL=postgresql://datamind:datamind@localhost:5432/datamind

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- File Upload ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# --- CORS (comma-separated origins) ---
# Note: Multiple origins should be comma-separated. Whitespace will be automatically stripped.
# Examples: 
#   Single origin: http://localhost:3000
#   Multiple origins: http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
